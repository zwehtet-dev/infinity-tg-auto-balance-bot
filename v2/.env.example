# =============================================================================
# Infinity Balance Bot v2 — configuration template
# Copy to .env and fill in real values. NEVER commit real secrets to git.
# =============================================================================

# --- Telegram (required) -----------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TARGET_GROUP_ID=-1001234567890

# Forum topic ids (0 = disabled / use main chat)
USDT_TRANSFERS_TOPIC_ID=0
AUTO_BALANCE_TOPIC_ID=0
ACCOUNTS_MATTER_TOPIC_ID=0
ALERT_TOPIC_ID=0

# --- OpenAI (required, used for receipt OCR) ---------------------------------
OPENAI_API_KEY=your_openai_api_key

# --- Database ------------------------------------------------------------------
# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://bot_user:strong_password@127.0.0.1:5432/infinity_bot
# SQLite fallback (used when DATABASE_URL is unset)
# SQLITE_DB_FILE=bot_data.db

# --- Security ------------------------------------------------------------------
# Comma-separated Telegram user ids allowed to run admin commands
# (/set_user, /set_mmk_bank, ...). Empty = anyone in the group (v1-compatible).
ADMIN_USER_IDS=

# --- Optional tuning (defaults shown) -------------------------------------------
# OCR_MODEL=gpt-4o
# OCR_TIMEOUT_SECONDS=60
# OCR_MAX_ATTEMPTS=3
# OCR_MAX_CONCURRENCY=4
# MEDIA_GROUP_QUIET_SECONDS=2.5
# MEDIA_GROUP_MAX_WAIT_SECONDS=20
# TELEGRAM_TIMEOUT_SECONDS=60
# DROP_PENDING_UPDATES=true
# CLEANUP_INTERVAL_SECONDS=3600
# PHOTO_RETENTION_HOURS=24
# OCR_CACHE_RETENTION_HOURS=48
# AUDIT_RETENTION_DAYS=365
# MEDIA_GROUP_DIR=media_group_photos
